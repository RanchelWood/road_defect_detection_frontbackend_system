# Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET_KEY=replace_me_with_secure_value
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_MINUTES=10080
DATABASE_URL=sqlite:///./data/app.db
MEDIA_ROOT=./media
MAX_UPLOAD_MB=10
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png
YOLO_DEVICE=cpu
# ORDDC2024
ORDDC2024_PYTHON_PATH=D:\anaconda3\envs\orddc2024\python.exe
ORDDC2024_ROOT=D:\road_defect_detection\orddc2024-main
ORDDC2024_TIMEOUT_SECONDS=180

# SHIYU_GRDDC2022
SHIYU_GRDDC2022_PYTHON_PATH=D:\anaconda3\envs\crddc2022\python.exe
SHIYU_GRDDC2022_ROOT=D:\road_defect_detection\ShiYu_SeaView_GRDDC2022
SHIYU_GRDDC2022_DEVICE=cpu
SHIYU_GRDDC2022_TIMEOUT_SECONDS_SINGLE=180
SHIYU_GRDDC2022_TIMEOUT_SECONDS_ENSEMBLE=360
# Frontend
VITE_API_BASE_URL=http://localhost:8000

